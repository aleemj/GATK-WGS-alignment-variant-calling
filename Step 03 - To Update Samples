################ Step 3: Joint Genotyping - UPDATING SAMPLES ################
# Function: This script performs joint genotyping on an updated set of GVCFs when one wants to ADD new samples to previous GenomicsDB.
# It utilises a sample map with new sample GVCFs, imports them 
# into previous GenomicsDB workspace using GATK --genomicsdb-update-workspace-path, and then 
# generates a joint VCF using GenotypeGVCFs.
# Parellel runs 100 jobs to speed up process -> chunks

# User should edit the variables at the top:
# REF, SAMPLE_MAP_NEW, INTERVALS_DIR, VCF_DIR, DB_DIR, OUT_DIR, VCF_OUT, CHUNKS
# Notes:
# IMPORTANT - ALL INFORMATION AND FILES MUST BE SAME AS PREVIOUS GENOMICSDB
# - DB_DIR should be empty for a new GenomicsDB workspace
# - Use --genomicsdb-update-workspace-path to add new samples later
# - REF_INTERVALS should be a line-separated list of scaffolds/chromosomes

#!/bin/bash
# Configuration
REF="/home/users/nus/e1583429/scratch/esativa_WGS_alignment/ref/Arugula_ref_gen_V2/E_sativa.genome.final.fa"
SH_DIR="/home/users/nus/e1583429/scratch/esativa_WGS_alignment/sh_files"
VCF_DIR="/home/users/nus/e1583429/scratch/esativa_WGS_alignment/vcf_files"
SAMPLE_MAP_NEW="$VCF_DIR/sample_map_new.txt"
INTERVALS_DIR="/home/users/nus/e1583429/scratch/esativa_WGS_alignment/ref/interval_lists_100"
DB_DIR="/home/users/nus/e1583429/scratch/esativa_WGS_alignment/genomics_dbs"
VCF_OUT="/home/users/nus/e1583429/scratch/esativa_WGS_alignment/final_vcf"
CHUNKS=100           # should match existing DB count

cd $SH_DIR

mkdir -p update_jobs logs "$VCF_OUT"

# 2. Generate PBS scripts
for i in $(seq 0 $((CHUNKS-1)))
do
    CHUNK_ID=$(printf "%04d" $i)
    SCRIPT="update_jobs/update_gatk_${CHUNK_ID}.sh"

    cat <<EOT > $SCRIPT
#!/bin/bash
#PBS -q normal
#PBS -l select=1:ncpus=2:mem=64G
#PBS -l walltime=24:00:00
#PBS -N UpdateGenotyping_${CHUNK_ID}
#PBS -o logs/${CHUNK_ID}.out
#PBS -e logs/${CHUNK_ID}.err

cd \$PBS_O_WORKDIR

module load gatk samtools python

DB_PATH=${DB_DIR}/db_chunk_${CHUNK_ID}

# 🚨 Safety check
if [ ! -d "\$DB_PATH" ]; then
    echo "ERROR: DB chunk ${CHUNK_ID} does not exist. Cannot update."
    exit 1
fi

echo "Updating DB chunk ${CHUNK_ID}"

# GenomicsDB UPDATE (only new samples)
gatk --java-options "-Xmx16G" GenomicsDBImport \\
    --genomicsdb-update-workspace-path \$DB_PATH \\
    --batch-size 50 \\
    -L ${INTERVALS_DIR}/${CHUNK_ID}-scattered.interval_list \\
    --sample-name-map ${SAMPLE_MAP_NEW} \\
    --reader-threads 2

echo "Running GenotypeGVCFs for chunk ${CHUNK_ID}"

# Genotype full cohort (old + new)
gatk --java-options "-Xmx48G" GenotypeGVCFs \\
    -R ${REF} \\
    -V gendb://\$DB_PATH \\
    -O ${VCF_OUT}/part_${CHUNK_ID}.vcf.gz

EOT

    chmod +x $SCRIPT
done

echo "Success: Created update jobs in 'update_jobs/' folder."
